generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String?
  pseudo       String?
  role         Role      @default(CLIENT)
  billingCurrency String? @map("billing_currency")
  phone        String?
  company      String?
  address      String?   @db.Text
  totpSecret   String?   @map("totp_secret")
  totpEnabled  Boolean   @default(false) @map("totp_enabled")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions              Session[]
  projectsAsClient      Project[]              @relation("ProjectClient")
  projectsAsCollab      ProjectCollaborator[]
  timeSessions          TimeSession[]
  taskComments          TaskComment[]
  projectRequests       ProjectRequest[]
  attachments           Attachment[]
  documents             Document[]
  htmlPages             HtmlPage[]
  sentMessages          Message[]
  invitationsCreated    Invitation[]
  projectFiles          ProjectFile[]
  clientFiles           ClientFile[]
  clientFilesUploaded   ClientFile[]  @relation("ClientFileUploader")
  invoices              Invoice[]
  projectLinks          ProjectLink[]
  taskLinks             TaskLink[]
  phaseLinks            PhaseLink[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum Role {
  ADMIN
  COLLABORATEUR
  CLIENT
}

// ==================== PROJETS ====================

model Project {
  id          String        @id @default(cuid())
  name          String
  description   String?       @db.Text
  status        ProjectStatus @default(DRAFT)
  billingType   String        @default("TJM") @map("billing_type")
  tjm           Float         @default(0)
  forfaitAmount Float?        @map("forfait_amount")
  clientId      String        @map("client_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  client        User                  @relation("ProjectClient", fields: [clientId], references: [id])
  collaborators ProjectCollaborator[]
  phases        Phase[]
  requests      ProjectRequest[]
  documents     Document[]
  files         ProjectFile[]
  htmlPages     HtmlPage[]
  messages      Message[]
  links         ProjectLink[]

  @@map("projects")
}

model ProjectCollaborator {
  projectId      String @map("project_id")
  collaboratorId String @map("collaborator_id")

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collaborator User    @relation(fields: [collaboratorId], references: [id])

  @@id([projectId, collaboratorId])
  @@map("project_collaborators")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// ==================== PHASES & TÂCHES ====================

model Phase {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  projectId String   @map("project_id")
  createdAt DateTime @default(now()) @map("created_at")

  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks        Task[]
  requests     ProjectRequest[]
  projectFiles ProjectFile[]
  phaseLinks   PhaseLink[]

  @@map("phases")
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  phaseId     String     @map("phase_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  phase        Phase            @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  todos        TodoItem[]
  timeSessions TimeSession[]
  comments     TaskComment[]
  attachments  Attachment[]
  links        TaskLink[]
  requests     ProjectRequest[]
  resources    TaskResource[]

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  VALIDATED
}

// ==================== CHECKLIST ====================

model TodoItem {
  id        String   @id @default(cuid())
  label     String
  checked   Boolean  @default(false)
  order     Int      @default(0)
  taskId    String   @map("task_id")
  createdAt DateTime @default(now()) @map("created_at")

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("todo_items")
}

// ==================== TIME TRACKING ====================

model TimeSession {
  id              String    @id @default(cuid())
  taskId          String    @map("task_id")
  userId          String    @map("user_id")
  startedAt       DateTime  @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")

  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id])

  @@map("time_sessions")
}

model TimeSessionDeletionLog {
  id              String   @id @default(cuid())
  sessionId       String   @map("session_id")
  taskId          String   @map("task_id")
  userId          String   @map("user_id")
  startedAt       DateTime @map("started_at")
  endedAt         DateTime @map("ended_at")
  durationSeconds Int      @map("duration_seconds")
  reason          String   @db.Text
  deletedById     String   @map("deleted_by_id")
  deletedAt       DateTime @default(now()) @map("deleted_at")

  @@map("time_session_deletion_logs")
}

// ==================== MESSAGERIE ====================

model Message {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@map("messages")
}

// ==================== PAGES HTML ====================

model HtmlPage {
  id               String   @id @default(cuid())
  projectId        String   @map("project_id")
  uploadedByUserId String   @map("uploaded_by_user_id")
  title            String
  filename         String
  createdAt        DateTime @default(now()) @map("created_at")

  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy       User           @relation(fields: [uploadedByUserId], references: [id])
  taskResources    TaskResource[]

  @@map("html_pages")
}

// ==================== DOCUMENTS ====================

model Document {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  authorId  String   @map("author_id")
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id])
  taskResources TaskResource[]

  @@map("documents")
}

// ==================== PIÈCES JOINTES ====================

model Attachment {
  id               String   @id @default(cuid())
  taskId           String   @map("task_id")
  uploadedByUserId String   @map("uploaded_by_user_id")
  filename         String
  originalName     String   @map("original_name")
  mimeType         String   @map("mime_type")
  size             Int
  uploadedAt       DateTime @default(now()) @map("uploaded_at")

  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy       User     @relation(fields: [uploadedByUserId], references: [id])

  @@map("attachments")
}

// ==================== FICHIERS PROJET ====================

model ProjectFile {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  uploadedById String   @map("uploaded_by_id")
  phaseId      String?  @map("phase_id")
  filename     String
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy    User           @relation(fields: [uploadedById], references: [id])
  phase         Phase?         @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  taskResources TaskResource[]

  @@map("project_files")
}

// ==================== FICHIERS CLIENT (contrats, devis…) ====================

model ClientFile {
  id           String   @id @default(cuid())
  clientId     String   @map("client_id")
  uploadedById String   @map("uploaded_by_id")
  filename     String
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  label        String?
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  client       User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("ClientFileUploader", fields: [uploadedById], references: [id])

  @@map("client_files")
}

// ==================== FACTURES ====================

model Invoice {
  id          String        @id @default(cuid())
  clientId    String        @map("client_id")
  number      String
  amount      Float
  currency    String?
  status      InvoiceStatus @default(PENDING)
  issuedAt    DateTime      @map("issued_at")
  dueAt       DateTime?     @map("due_at")
  paidAt      DateTime?     @map("paid_at")
  filename    String?
  originalName String?      @map("original_name")
  createdAt   DateTime      @default(now()) @map("created_at")

  client      User          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ==================== COMMENTAIRES ====================

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@map("task_comments")
}

// ==================== DEMANDES ====================

model ProjectRequest {
  id          String        @id @default(cuid())
  projectId   String        @map("project_id")
  authorId    String        @map("author_id")
  phaseId     String?       @map("phase_id")
  taskId      String?       @map("task_id")
  title       String
  description String?       @db.Text
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User          @relation(fields: [authorId], references: [id])
  phase       Phase?        @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  task        Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("project_requests")
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REFUSED
  QUOTED
}

// ==================== PARAMÈTRES ====================

model AppSettings {
  id          String @id @default("default")
  hoursPerDay Float  @default(8) @map("hours_per_day")
  currency    String @default("EUR")

  @@map("app_settings")
}

// ==================== LIENS ====================

model ProjectLink {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  url         String
  title       String?
  description String?  @db.Text
  image       String?
  addedById   String   @map("added_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  addedBy     User     @relation(fields: [addedById], references: [id])

  @@map("project_links")
}

model TaskLink {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  url         String
  title       String?
  description String?  @db.Text
  image       String?
  addedById   String   @map("added_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  addedBy     User     @relation(fields: [addedById], references: [id])

  @@map("task_links")
}

// ==================== RESSOURCES PAR PHASE ====================

model PhaseLink {
  id        String   @id @default(cuid())
  phaseId   String   @map("phase_id")
  url       String
  title     String?
  addedById String   @map("added_by_id")
  createdAt DateTime @default(now()) @map("created_at")

  phase     Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  addedBy   User     @relation(fields: [addedById], references: [id])

  @@map("phase_links")
}

// ==================== RESSOURCES LIÉES AUX TÂCHES ====================

model TaskResource {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  fileId    String?  @map("file_id")
  pageId    String?  @map("page_id")
  docId     String?  @map("doc_id")
  createdAt DateTime @default(now()) @map("created_at")

  task     Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  file     ProjectFile?  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  page     HtmlPage?     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  document Document?     @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@map("task_resources")
}

// ==================== INVITATIONS ====================

model Invitation {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String?
  role      Role
  createdBy String    @map("created_by")
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  creator   User      @relation(fields: [createdBy], references: [id])

  @@map("invitations")
}
